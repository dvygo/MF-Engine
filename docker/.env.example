# Copy to .env in this folder and set real values before `docker compose up`.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me

# Sized for 6GB VRAM (RTX 3050): 3B params, AWQ 4-bit ~1.9GB weights.
# Too tight? Drop to Qwen/Qwen2.5-1.5B-Instruct-AWQ.
# Bigger GPU later? Qwen/Qwen3-8B + VLLM_MAX_MODEL_LEN=8192.
VLLM_MODEL=Qwen/Qwen2.5-3B-Instruct-AWQ
VLLM_MAX_MODEL_LEN=2048

# Only needed for gated HuggingFace models.
HF_TOKEN=

# Phase 4 search backend. SearXNG (self-hosted, no key) is the default —
# start it with `docker compose up -d searxng`, then run the scraper with this set.
SEARXNG_URL=http://localhost:8080
# Optional alternatives (leave blank to use SearXNG):
#   ANTHROPIC_API_KEY=   # same web_search backend Claude Code uses
#   SERPAPI_KEY=
#   HUNTER_API_KEY=      # verified emails
